# Optional: public site URL (callbacks, canonicals).
APP_URL="https://example.com"

# Lead capture — E.164 digits only (e.g. Mexico: 521 + 10 digits).
VITE_WHATSAPP_PHONE="5210000000000"
# Optional pre-filled WhatsApp message (plain text).
VITE_WHATSAPP_MESSAGE="Hola, me interesa una cotización de MP Web Solutions."

# Used if VITE_WHATSAPP_PHONE is empty (mailto fallback).
VITE_CONTACT_EMAIL="contacto@example.com"

# Public URL to PDF resume (opens in new tab).
VITE_RESUME_URL="https://example.com/mp-web-solutions-resume.pdf"

VITE_LINKEDIN_URL="https://www.linkedin.com/in/yourprofile"
VITE_GITHUB_URL="https://github.com/youruser"
